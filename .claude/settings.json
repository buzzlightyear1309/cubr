{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",

      "Bash(cargo check)",
      "Bash(cargo check:*)",
      "Bash(cargo build)",
      "Bash(cargo build:*)",
      "Bash(cargo test)",
      "Bash(cargo test:*)",
      "Bash(cargo run)",
      "Bash(cargo run:*)",
      "Bash(cargo clippy)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt)",
      "Bash(cargo fmt:*)",
      "Bash(cargo tree:*)",
      "Bash(cargo add:*)",

      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git ls-files:*)",
      "Bash(git stash list:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",

      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sed:*)",
      "Bash(tree:*)",

      "Bash(curl*localhost:3000*)",
      "Bash(curl*127.0.0.1:3000*)",

      "Bash(screencapture:*)"
    ]
  }
}
